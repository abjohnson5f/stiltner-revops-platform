# =============================================================================
# Nginx Configuration for RevOps Dashboard
# Location: /etc/nginx/sites-available/marketing.stiltnerlandscapes.com
# =============================================================================

# Redirect HTTP to HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name marketing.stiltnerlandscapes.com;
    return 301 https://$server_name$request_uri;
}

# Main HTTPS server
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name marketing.stiltnerlandscapes.com;

    # SSL Certificate (generated via certbot)
    ssl_certificate /etc/letsencrypt/live/marketing.stiltnerlandscapes.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/marketing.stiltnerlandscapes.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_proxied any;
    gzip_types text/plain text/css text/xml text/javascript application/javascript application/x-javascript application/xml application/json;

    # Proxy to Next.js
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 86400;
    }

    # Cache static files
    location /_next/static {
        proxy_pass http://127.0.0.1:3000;
        proxy_cache_valid 200 365d;
        expires 365d;
        add_header Cache-Control "public, immutable";
    }

    # Cache public assets
    location /public {
        proxy_pass http://127.0.0.1:3000;
        expires 30d;
        add_header Cache-Control "public";
    }

    # Health check endpoint
    location /api/health {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }
}

# =============================================================================
# Setup Instructions:
# =============================================================================
#
# 1. Copy this file to Nginx sites-available:
#    sudo cp nginx.conf.example /etc/nginx/sites-available/marketing.stiltnerlandscapes.com
#
# 2. Create symlink to enable:
#    sudo ln -s /etc/nginx/sites-available/marketing.stiltnerlandscapes.com /etc/nginx/sites-enabled/
#
# 3. Test configuration:
#    sudo nginx -t
#
# 4. Reload Nginx:
#    sudo systemctl reload nginx
#
# 5. Get SSL certificate (after DNS is configured):
#    sudo certbot --nginx -d marketing.stiltnerlandscapes.com
#
# =============================================================================
